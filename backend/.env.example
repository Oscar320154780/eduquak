DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
JWT_SECRET=CAMBIA_ESTE_SECRETO_LARGO
PORT=3000
PGSSL=true
NODE_ENV=development
APP_TIMEZONE=America/Mexico_City

CLOUDINARY_CLOUD_NAME=TU_CLOUD_NAME
CLOUDINARY_API_KEY=TU_API_KEY
CLOUDINARY_API_SECRET=TU_API_SECRET

GEMINI_API_KEY=TU_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash-lite

MERCADOPAGO_PUBLIC_KEY=TU_PUBLIC_KEY_DE_EDUQUAK
MERCADOPAGO_ACCESS_TOKEN=TU_ACCESS_TOKEN_DE_EDUQUAK
MERCADOPAGO_CLIENT_ID=TU_CLIENT_ID_DE_LA_APP
MERCADOPAGO_CLIENT_SECRET=TU_CLIENT_SECRET_DE_LA_APP
MERCADOPAGO_REDIRECT_URI=http://localhost:3000/api/mercadopago/callback
MERCADOPAGO_MODO_MARKETPLACE=true
MERCADOPAGO_USAR_SANDBOX=false
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000
COMISION_EDUQUAK=0.15
PRECIO_BASE_ASESORIA=100
PRECIO_MINIMO_ASESORIA=80
PAGOS_CONFIAR_RETORNO=true
